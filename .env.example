# -- X (Twitter) API ------------------------------------------------------
# Required for live data. Create a Bearer Token in the X Developer portal
# with "Read" permissions. The token is only ever used server-side.
X_BEARER_TOKEN=

# -- xAI (Grok) -----------------------------------------------------------
# Required for section summaries and key takeaways.
# Use the fastest reasoning model available; defaults to grok-4-1-fast-reasoning.
XAI_API_KEY=
XAI_MODEL=grok-4-1-fast-reasoning

# -- Supabase -------------------------------------------------------------
# Optional but recommended. Without Supabase, Pulse still runs - it uses
# an in-memory cache per server instance instead of a durable one.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Public/anon key is exposed via NEXT_PUBLIC_* if you later build read-only
# client features that talk to Supabase directly.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -- Cache ---------------------------------------------------------------
# How long (in minutes) to reuse a section fetch before re-calling X + Grok.
# 15-30 is a good range for news-like content.
CACHE_TTL_MINUTES=20

# -- xAI (Grok) -----------------------------------------------------------
# Required. Bylines is built around the xAI Responses API, which powers
# Grok's research and writing. The service role key is used for live
# web_search + x_search tool calls, so this key needs those tools enabled.
XAI_API_KEY=
# Model to use for research and writing. A fast reasoning model is best.
XAI_MODEL=grok-4-fast-reasoning
# Optional override (defaults to https://api.x.ai/v1/responses).
# XAI_RESPONSES_URL=

# -- Supabase -------------------------------------------------------------
# Required. Bylines stores all articles, authors, topics, and generation
# runs in Supabase. The anon key is used for public reads; the service
# role key is used for writes from /api/generate.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional; falls back to NEXT_PUBLIC_SUPABASE_URL.
# SUPABASE_URL=

# -- Generation endpoint --------------------------------------------------
# Optional shared secret required to call /api/generate. If empty, the
# endpoint is open (fine for local dev). Set this in production and pass
# it as `Authorization: Bearer <secret>` or `?secret=<secret>`.
GENERATE_SECRET=

# -- Public site URL (for sitemap only) ----------------------------------
# NEXT_PUBLIC_SITE_URL=https://bylines.example.com
